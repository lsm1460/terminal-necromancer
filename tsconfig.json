{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "outDir": "./dist",
    "types": ["node"],
    "baseUrl": ".", 
    "paths": {
      "~/*": ["src/*"]
    }
  }
}